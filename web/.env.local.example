# ── 登录认证 ──
AUTH_USERNAME=admin
AUTH_PASSWORD=traffic2026
# AUTH_SECRET=your-random-secret-string

# 技能调用模式：simulated | llm | openclaw
# - simulated: 本地模拟，无需任何 API Key（默认）
# - llm: 直连 Anthropic Claude API
# - openclaw: 通过本地 OpenClaw Gateway 调用
SKILL_MODE=simulated

# ── 方案 A：直连 LLM API（SKILL_MODE=llm 时需要） ──
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-xxx
# 可选：指定模型（默认 claude-sonnet-4-20250514）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 方案 B：OpenClaw Gateway（SKILL_MODE=openclaw 时需要） ──
# 通过 openclaw agent CLI 子进程调用，需确保 openclaw 在 PATH 中
# OPENCLAW_BIN=openclaw             # 可选：指定 openclaw 二进制路径
OPENCLAW_AUTH_TOKEN=
# OPENCLAW_TIMEOUT=120              # 可选：Agent 超时秒数（默认 120）
